# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/suraksha_db

# External API Keys
OPENWEATHER_API_KEY=your_openweather_api_key_here
OPENWEATHER_API_URL=https://api.openweathermap.org/data/2.5
OPENAQ_API_URL=https://api.openaq.org/v2

# Trigger Thresholds (Parametric)
TRIGGER_HEAVY_RAIN_MM=5.0
TRIGGER_EXTREME_HEAT_C=42.0
TRIGGER_POLLUTION_AQI=300

# Service Configuration
SERVICE_PORT=8003
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Optional: Polling Configuration (if using background poller)
# POLL_INTERVAL_SECONDS=300
# POLL_LOCATIONS=Bangalore,Delhi,Mumbai
