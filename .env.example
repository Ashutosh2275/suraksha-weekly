# ──────────────────────────────────────────────────────────────────────────────
# Suraksha Weekly - Local Development Environment
# ──────────────────────────────────────────────────────────────────────────────

# Database Configuration
POSTGRES_USER=suraksha
POSTGRES_PASSWORD=suraksha_dev_pass
POSTGRES_DB=suraksha_db
POSTGRES_PORT=5432

# Redis Configuration
REDIS_PORT=6379

# RabbitMQ Configuration
RABBITMQ_USER=suraksha
RABBITMQ_PASSWORD=suraksha_dev_pass
RABBITMQ_VHOST=/
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Service Ports
API_PORT=8000
FRAUD_PORT=8001
TRIGGER_PORT=8002
WORKER_WEB_PORT=3000
ADMIN_WEB_PORT=3001

# Application Configuration
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=dev-secret-key-change-in-production-12345678901234567890
JWT_SECRET=jwt-secret-key-change-in-production-12345678901234567890
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# External API Keys
OPENWEATHER_API_KEY=your_openweather_api_key_here
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Feature Flags
MOCK_MODE=true
MOCK_WEATHER_DATA=true
MOCK_AQI_DATA=true
MOCK_PLATFORM_OUTAGE=true

# Fraud Detection Thresholds
FRAUD_THRESHOLD_HIGH=0.6
FRAUD_THRESHOLD_CRITICAL=0.85

# Trigger Thresholds (Parametric)
TRIGGER_HEAVY_RAIN_MM=5.0
TRIGGER_EXTREME_HEAT_C=42.0
TRIGGER_POLLUTION_AQI=300
